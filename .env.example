# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/skillpath
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/skillpath

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─── YouTube Data API ─────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Reddit API (PRAW) ────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SkillPathAI/1.0 (resource-validator)

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change_this_to_a_strong_random_secret

# ─── Scraper Settings ─────────────────────────────────────────────────────────
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SCRAPER_CONCURRENCY=3
# ── Exa AI (AI-powered web search for Udemy) ────────────────────────────────
EXA_API_KEY=843ad331-88c0-4719-8b81-320a575813ef
# ─── Apify (for Udemy scraping) ───────────────────────────────────────────────
APIFY_API_KEY=your_apify_api_key_here

# ─── Credibility Score Weights ────────────────────────────────────────────────
# Must sum to 1.0
WEIGHT_RESOURCE_METADATA=0.35
WEIGHT_COMMUNITY_SENTIMENT=0.30
WEIGHT_PLATFORM_ENGAGEMENT=0.20
WEIGHT_TIME_DECAY=0.15
